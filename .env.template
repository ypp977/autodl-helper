# AutoDL authentication (prefer Authorization, or use phone/password for Playwright login fallback)
Authorization=
AUTODL_PHONE=
AUTODL_PASSWORD=
AUTODL_LOGIN_RETRIES=3
AUTODL_LOGIN_TIMEOUT_MS=15000
AUTODL_POST_LOGIN_WAIT_SECONDS=8
AUTODL_AUTH_CACHE_FILE=
AUTODL_AUTH_CACHE_MAX_AGE_SECONDS=86400

# Keep-alive compatibility setting
MIN_DAY=7

# Push notifications
PUSHPLUS_TOKEN=
SERVERCHAN_SENDKEY=

# Email notifications
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
