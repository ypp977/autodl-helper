[importlinter]
root_package = autodl_helper

[importlinter:contract:core tasks and services must not import cli or ui]
name = Core, tasks, and services must not import CLI or UI
source_modules =
    autodl_helper.core
    autodl_helper.api
    autodl_helper.auth
    autodl_helper.config
    autodl_helper.notify
    autodl_helper.runtime
    autodl_helper.services
    autodl_helper.storage
    autodl_helper.tasks
forbidden_modules =
    autodl_helper.cli
    autodl_helper.ui
type = forbidden

[importlinter:contract:ui must not import cli app]
name = UI must not import CLI app
source_modules =
    autodl_helper.ui
forbidden_modules =
    autodl_helper.cli.app
type = forbidden

[importlinter:contract:cli internals must not import cli entrypoints]
name = CLI internals must not import CLI entrypoints
source_modules =
    autodl_helper.cli.shared
    autodl_helper.cli.shared_accounts
    autodl_helper.cli.shared_edit
    autodl_helper.cli.shared_healthcheck
    autodl_helper.cli.shared_notifications
    autodl_helper.cli.shared_scheduled
    autodl_helper.cli.shared_settings
    autodl_helper.cli.commands
forbidden_modules =
    autodl_helper.cli.app
type = forbidden
